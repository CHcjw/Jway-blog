# Hidden admin panel route path
# Example: /my-super-hidden-console
VITE_ADMIN_PANEL_PATH=/replace-with-hidden-panel-path

# Hidden admin API prefix (should align with backend ADMIN_API_PREFIX without /api base overlap)
# Example backend: /api/secret-cms-x9
# Example frontend: /secret-cms-x9
VITE_ADMIN_API_PREFIX=/replace-with-hidden-api-prefix
