# Backend admin credentials (required)
ADMIN_API_PREFIX=/api/replace_with_hidden_admin_api_prefix
ADMIN_ENTRY_KEY=replace_with_strong_entry_key
ADMIN_USERNAME=replace_with_admin_username
# Recommended: use password hash instead of plain password
ADMIN_PASSWORD_HASH=$2a$10$replace_with_bcrypt_hash
# Optional fallback (not recommended)
ADMIN_PASSWORD=

# Optional MySQL config
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=jway_blog
MYSQL_USER=root
MYSQL_PASSWORD=root
